PORT=3000
NODE_ENV=development
SUPPORTED_LANGUAGES=en,es,fr
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bran_be?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bran_be
MASTER_DB_NAME=main
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable
MELTWATER_BASE_URL=https://api.meltwater.com
MELTWATER_API_KEY=your_meltwater_api_key
MELTWATER_OWNED_POSTS_ENDPOINT=/v3/owned/accounts/posts/top_posts
MELTWATER_ACCOUNT_IDS_INSTAGRAM=12345678945687234
MELTWATER_ACCOUNT_IDS_LINKEDIN=urn:li:organization:12522
MELTWATER_ACCOUNT_IDS_YOUTUBE=UCXXXXXXXXXXXXXXX
MELTWATER_ACCOUNT_IDS_FACEBOOK=114660283267581
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_IDS=your_web_client_id,your_android_client_id,your_ios_client_id
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRES_IN=7d
AI_PROVIDER=gemini
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
QDRANT_URL=https://qdrant-production-dc6d.up.railway.app
QDRANT_API_KEY=your_qdrant_api_key
APIFY_TOKEN=your_apify_api_token
APIFY_INSTAGRAM_ACTOR_ID=apify/instagram-scraper
YOUTUBE_API_KEY=your_youtube_data_api_key
INSTAGRAM_ACCESS_TOKEN=your_instagram_graph_api_long_lived_token

# App URL used inside outgoing email templates (links back to the dashboard).
APP_URL=http://localhost:3000

# Address always cc'd on rental-resource request notifications. Resolved to a
# user record by email; if no matching user exists the admin recipient is
# silently dropped.
NOTIFICATIONS_ADMIN_EMAIL=admin@bran.app

# SMTP for outbound notification email. All optional — if SMTP_HOST is empty
# the app will skip email sending and only persist in-app notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Bran <no-reply@bran.local>"

# S3-compatible object storage (Railway bucket). When configured, uploads use the bucket
# instead of local data/ directories. Falls back to local disk when unset.
S3_ENDPOINT=https://t3.storageapi.dev
S3_REGION=auto
S3_BUCKET=your_bucket_name
S3_ACCESS_KEY_ID=your_s3_access_key_id
S3_SECRET_ACCESS_KEY=your_s3_secret_access_key
S3_FORCE_PATH_STYLE=false
S3_AUDIO_PREFIX=audio
S3_VISION_PREFIX=visions
S3_THUMBNAIL_PREFIX=thumbnails
