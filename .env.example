PORT=3000
NODE_ENV=development
SUPPORTED_LANGUAGES=en,es,fr
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bran_be?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bran_be
MASTER_DB_NAME=main
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable
MELTWATER_BASE_URL=https://api.meltwater.com
MELTWATER_API_KEY=your_meltwater_api_key
MELTWATER_OWNED_POSTS_ENDPOINT=/v3/owned/accounts/posts/top_posts
MELTWATER_ACCOUNT_IDS_INSTAGRAM=12345678945687234
MELTWATER_ACCOUNT_IDS_LINKEDIN=urn:li:organization:12522
MELTWATER_ACCOUNT_IDS_YOUTUBE=UCXXXXXXXXXXXXXXX
MELTWATER_ACCOUNT_IDS_FACEBOOK=114660283267581
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_IDS=your_web_client_id,your_android_client_id,your_ios_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/google/calendar/callback
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.events.readonly,openid,email,profile
GOOGLE_GMAIL_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/google/gmail/callback
GOOGLE_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly,openid,email,profile

# Gmail sync (direct Google API — refresh token encrypted at rest)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
GMAIL_SYNC_CRON_ENABLED=true
GMAIL_SYNC_INTERVAL_MS=300000
GMAIL_SYNC_DAYS=7
GMAIL_SYNC_MAX_MESSAGES=50

# Org Events — AI clustering of Gmail/Meet/Slack/work/attendance into events
# Detection runs on this interval but only calls the LLM when the set of
# unattached sources actually changes, so a short interval stays cheap.
EVENTS_DETECT_CRON_ENABLED=true
EVENTS_DETECT_INTERVAL_MS=300000
EVENTS_DETECT_DAYS=14
EVENTS_DETECT_MAX_CANDIDATES=80

# Recall.ai meeting bot integration (usage-based, ~$0.50/recording-hour)
RECALL_API_KEY=your_recall_api_key
RECALL_API_REGION=us-east-1
RECALL_WEBHOOK_SECRET=whsec_your_recall_webhook_secret
MEETING_BOT_NAME=Bran Notetaker
# Periodic safety-net re-sync so bots auto-join all connected calendars' Meet calls
MEETINGS_SYNC_CRON_ENABLED=true
MEETINGS_SYNC_INTERVAL_MS=300000
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRES_IN=7d
AI_PROVIDER=gemini
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
QDRANT_URL=https://qdrant-production-dc6d.up.railway.app
QDRANT_API_KEY=your_qdrant_api_key
APIFY_TOKEN=your_apify_api_token
APIFY_INSTAGRAM_ACTOR_ID=apify/instagram-scraper
YOUTUBE_API_KEY=your_youtube_data_api_key
INSTAGRAM_ACCESS_TOKEN=your_instagram_graph_api_long_lived_token

# App URL used inside outgoing email templates (links back to the dashboard).
APP_URL=http://localhost:3000

# Address always cc'd on rental-resource request notifications. Resolved to a
# user record by email; if no matching user exists the admin recipient is
# silently dropped.
NOTIFICATIONS_ADMIN_EMAIL=admin@bran.app

# SMTP for outbound notification email. All optional — if SMTP_HOST is empty
# the app will skip email sending and only persist in-app notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Bran <no-reply@bran.local>"

# S3-compatible object storage (Railway bucket). When configured, uploads use the bucket
# instead of local data/ directories. Falls back to local disk when unset.
S3_ENDPOINT=https://t3.storageapi.dev
S3_REGION=auto
S3_BUCKET=your_bucket_name
S3_ACCESS_KEY_ID=your_s3_access_key_id
S3_SECRET_ACCESS_KEY=your_s3_secret_access_key
S3_FORCE_PATH_STYLE=false
S3_AUDIO_PREFIX=audio
S3_VISION_PREFIX=visions
S3_THUMBNAIL_PREFIX=thumbnails

# ── Attendance / ETA tracker (Slack #cs-day-off) ──
# Bot User OAuth Token — OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-XXXXXXXXXXXX-XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXX
# Signing Secret — Basic Information → App Credentials
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Channel name without # (or set SLACK_CHANNEL_ID to skip lookup)
SLACK_CHANNEL_NAME=cs-day-off
# SLACK_CHANNEL_ID=C0ABN0W36ES
# Bearer secret for GET /api/cron/eta-check
CRON_SECRET=your-random-secret-here
# Only emails ending with @this domain are recorded
ATTENDANCE_EMAIL_DOMAIN=mastersunion.org
# Comma-separated emails allowed to receive attendance Slack DMs.
# Empty = all eligible people. Example for safe testing:
# ATTENDANCE_DM_ALLOWLIST=abhishek.ghosh1@mastersunion.org
ATTENDANCE_DM_ALLOWLIST=
# In-process weekday 11:00 IST scheduler (also expose HTTP cron endpoint)
ATTENDANCE_CRON_ENABLED=true

# ── Escalation tracker (Slack escalation group/channel) ──
# Channel name without # (or set SLACK_ESCALATION_CHANNEL_ID to skip lookup)
SLACK_ESCALATION_CHANNEL_NAME=escalation-matrix
# SLACK_ESCALATION_CHANNEL_ID=C0XXXXXXXXXX
# In-process daily 10:00 IST sync + AI refresh (also GET /api/cron/escalation-check)
ESCALATION_CRON_ENABLED=true
