generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth & RBAC ─────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model User {
  id           String    @id @default(uuid())
  googleId     String?
  email        String    @unique
  name         String
  avatarUrl    String?
  description  String?
  phone        String?
  designation  String?
  managerUserId String?
  passwordHash String?
  roleId       String
  isActive     Boolean   @default(true)
  /** Open role / new-hire slot on the org chart (not a real login account). */
  isPlaceholder Boolean  @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  role                      Role                    @relation(fields: [roleId], references: [id])
  manager                   User?                   @relation("UserManager", fields: [managerUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  directReports             User[]                  @relation("UserManager")
  tasks                     Task[]
  socialAccounts            SocialAccount[]
  teamMemberships           TeamMember[]
  teamLeadMemberships       TeamMember[]            @relation("TeamMemberReportsTo")
  createdTeams              Team[]                  @relation("TeamCreatedBy")
  projectMemberships        ProjectMember[]
  projectLeadMemberships    ProjectMember[]         @relation("ProjectMemberReportsTo")
  createdProjects           Project[]               @relation("ProjectCreatedBy")
  ownedVerticals            Vertical[]              @relation("VerticalOwner")
  createdContents           Content[]               @relation("ContentCreatedBy")
  contentNodeAssignments    ContentNodeTeamMember[] @relation("ContentNodeTeamUser")
  submittedContentOutputs   ContentNodeOutput[]     @relation("ContentOutputSubmittedBy")
  reviewedContentOutputs    ContentNodeOutput[]     @relation("ContentOutputReviewedBy")
  requestedContentResources ContentNodeResource[]   @relation("ResourceRequestedBy")
  reviewedContentResources  ContentNodeResource[]   @relation("ResourceReviewedBy")
  inventoryReservations     InventoryReservation[]  @relation("InventoryReservationCreatedBy")
  notifications             Notification[]          @relation("NotificationRecipient")
  ideas                     Idea[]                  @relation("IdeaAuthor")
  matchedIdeaRecommendations IdeaMatch[]            @relation("IdeaMatchTargetUser")
  adhocWork                 AdhocWork[]
  aiQueries                 AiQuery[]               @relation("AiQueryRequester")
  workUnits                 WorkUnit[]              @relation("WorkUnitOwner")
  createdWorkUnits          WorkUnit[]              @relation("WorkUnitCreatedBy")
  assignedWorkSteps         WorkStep[]              @relation("WorkStepAssignee")
  voiceRecordings           VoiceRecording[]        @relation("VoiceRecordingOwner")
  kpis                      UserKpi[]               @relation("UserKpiOwner")
  createdUserKpis           UserKpi[]               @relation("UserKpiCreatedBy")
  visionAssignments         VisionUser[]
  createdVisions            Vision[]                @relation("VisionCreatedBy")
  navSearchLogs             NavSearchLog[]
  pageVisits                UserPageVisit[]
  thumbnailGenerations    ThumbnailGeneration[]
  nameAssignmentPreferences NameAssignmentPreference[] @relation("NamePrefOwner")
  preferredNameAssignments  NameAssignmentPreference[] @relation("NamePrefTarget")
  calendarConnection        CalendarConnection?
  organizedMeetings         Meeting[]               @relation("MeetingOrganizer")
  attendanceStats           AttendancePersonStats[] @relation("AttendanceStatsUser")
  attendanceActionsTaken    AttendancePersonStats[] @relation("AttendanceStatsActionBy")

  @@index([roleId])
  @@index([managerUserId])
  @@index([email])
  @@index([googleId])
}

// ── Verticals ───────────────────────────────────────────────

model Vertical {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  ownerUserId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User?     @relation("VerticalOwner", fields: [ownerUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teams    Team[]
  projects Project[]

  @@index([ownerUserId])
  @@index([slug])
}

model Team {
  id          String   @id @default(uuid())
  name        String
  description String?
  verticalId  String
  createdById String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vertical  Vertical     @relation(fields: [verticalId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy User?        @relation("TeamCreatedBy", fields: [createdById], references: [id])
  members   TeamMember[]
  contents  Content[]
  visions   VisionTeam[]
  inventoryTeams InventoryItemTeam[]

  @@index([createdById])
  @@index([verticalId])
  @@index([name])
}

model TeamMember {
  id              String   @id @default(uuid())
  teamId          String
  userId          String
  memberRole      String   @default("MEMBER")
  reportsToUserId String?
  joinedAt        DateTime @default(now())
  isActive        Boolean  @default(true)

  team      Team  @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User  @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reportsTo User? @relation("TeamMemberReportsTo", fields: [reportsToUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@index([reportsToUserId])
}

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  objectives  String?
  finalLink   String?
  verticalId  String
  createdById String?
  status      String    @default("ACTIVE")
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vertical  Vertical        @relation(fields: [verticalId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy User?           @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  members   ProjectMember[]
  phases    ProjectPhase[]
  contents  Content[]
  workUnits WorkUnit[]

  @@index([createdById])
  @@index([verticalId])
  @@index([status])
  @@index([name])
}

model ProjectPhase {
  id         String    @id @default(uuid())
  projectId  String
  name       String
  objectives String?
  deadline   DateTime?
  status     String    @default("PLANNED")
  orderIndex Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([projectId])
  @@index([projectId, orderIndex])
  @@index([deadline])
}

model ProjectMember {
  id              String   @id @default(uuid())
  projectId       String
  userId          String
  memberRole      String   @default("MEMBER")
  reportsToUserId String?
  joinedAt        DateTime @default(now())
  isActive        Boolean  @default(true)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reportsTo User?   @relation("ProjectMemberReportsTo", fields: [reportsToUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([reportsToUserId])
}

// ── Task Tracking ───────────────────────────────────────────

model Task {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String?
  type        String    @default("GENERAL")
  platform    String?
  contentUrl  String?
  status      String    @default("PENDING")
  metadata    String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([type, platform])
}

// ── Adhoc Work ──────────────────────────────────────────────

model AdhocWork {
  id          String   @id @default(uuid())
  userId      String
  description String   @db.Text
  output      String?  @db.Text
  effortHours Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@index([userId, createdAt])
}

// ── User KPIs (expected outcomes per user, set by admin / chief of staff) ──

model UserKpi {
  id          String   @id @default(uuid())
  userId      String
  title       String   @db.VarChar(500)
  description String   @db.Text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  isKey       Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User @relation("UserKpiOwner", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  createdBy User @relation("UserKpiCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([createdById])
  @@index([userId, isActive])
  @@index([userId, sortOrder])
  @@index([userId, isKey])
}

// ── Vision documents (team / org direction, short or long term) ──

model Vision {
  id               String   @id @default(uuid())
  title            String   @db.VarChar(500)
  description      String?  @db.Text
  horizon          String   // SHORT_TERM | LONG_TERM
  durationMonths   Int
  startsAt         DateTime
  endsAt           DateTime
  scope            String   // ALL | SPECIFIC
  originalFilename String   @db.VarChar(500)
  mimeType         String   @db.VarChar(100)
  fileSizeBytes    Int
  storagePath      String   @db.VarChar(1000)
  createdById      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdBy User         @relation("VisionCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teams     VisionTeam[]
  users     VisionUser[]

  @@index([horizon])
  @@index([scope])
  @@index([startsAt, endsAt])
  @@index([createdById])
}

model VisionTeam {
  visionId String
  teamId   String

  vision Vision @relation(fields: [visionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([visionId, teamId])
  @@index([teamId])
}

model VisionUser {
  visionId String
  userId   String

  vision Vision @relation(fields: [visionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([visionId, userId])
  @@index([userId])
}

// ── Voice Recordings (platform-wide audio + transcript archive) ──

model VoiceRecording {
  id                  String   @id @default(uuid())
  userId              String
  source              String // work | ai_translate
  originalFilename    String   @db.VarChar(500)
  mimeType            String   @db.VarChar(100)
  fileSizeBytes       Int
  storagePath         String   @db.VarChar(1000)
  transcript          String?  @db.Text
  sarvamRequestId     String?  @db.VarChar(200)
  languageCode        String?  @db.VarChar(20)
  languageProbability Float?
  status              String   @default("COMPLETED") // COMPLETED | FAILED
  errorMessage        String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user      User       @relation("VoiceRecordingOwner", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workUnits WorkUnit[]
  meetings  Meeting[]

  @@index([userId])
  @@index([userId, createdAt])
  @@index([source])
}

// ── Google Meet / Calendar Integration ──────────────────────

model CalendarConnection {
  id               String   @id @default(uuid())
  userId           String   @unique
  provider         String   @default("google")
  recallCalendarId String   @unique @db.VarChar(200)
  oauthEmail       String?  @db.VarChar(320)
  status           String   @default("CONNECTED") // CONNECTED | DISCONNECTED | ERROR
  connectedAt      DateTime @default(now())
  disconnectedAt   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([status])
  @@index([recallCalendarId])
}

model Meeting {
  id               String    @id @default(uuid())
  organizerUserId  String
  recallBotId      String?   @unique @db.VarChar(200)
  calendarEventId  String?   @db.VarChar(200)
  meetingUrl       String    @db.VarChar(1000)
  title            String?   @db.VarChar(500)
  startTime        DateTime?
  status           String    @default("SCHEDULED") // SCHEDULED | JOINING | RECORDING | PROCESSING | COMPLETED | FAILED | CANCELLED
  voiceRecordingId String?
  errorMessage     String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organizer      User            @relation("MeetingOrganizer", fields: [organizerUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  voiceRecording VoiceRecording? @relation(fields: [voiceRecordingId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([organizerUserId])
  @@index([organizerUserId, createdAt])
  @@index([status])
  @@index([calendarEventId])
  @@index([voiceRecordingId])
}

// ── Work Units ──────────────────────────────────────────────

model WorkUnit {
  id                String    @id @default(uuid())
  userId            String
  createdById       String?
  projectId         String?
  audioRecordingId  String?
  title             String    @db.VarChar(500)
  context           String    @db.Text
  status            String    @default("OPEN") // OPEN | CLOSED
  isPrivate         Boolean   @default(false)
  closedAt          DateTime?
  nextDueAt         DateTime?
  firstDueAt        DateTime?
  assigneeSpokenName String?  @db.VarChar(200)
  sourceExcerpt      String?  @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user           User            @relation("WorkUnitOwner", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  createdBy      User?           @relation("WorkUnitCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  audioRecording VoiceRecording? @relation(fields: [audioRecordingId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  steps          WorkStep[]

  @@index([userId])
  @@index([createdById])
  @@index([userId, createdAt])
  @@index([status])
  @@index([isPrivate])
  @@index([nextDueAt])
  @@index([firstDueAt])
  @@index([closedAt])
  @@index([audioRecordingId])
  @@index([projectId])
}

model WorkStep {
  id          String    @id @default(uuid())
  workUnitId  String
  assigneeId  String?
  description String    @db.Text
  deadline    DateTime?
  done        Boolean   @default(false)
  assigneeSpokenName String? @db.VarChar(200)
  sourceExcerpt      String? @db.Text
  createdAt   DateTime  @default(now())

  workUnit WorkUnit @relation(fields: [workUnitId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  assignee User?    @relation("WorkStepAssignee", fields: [assigneeId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([workUnitId])
  @@index([assigneeId])
  @@index([deadline])
}

model NameAssignmentPreference {
  id          String   @id @default(uuid())
  ownerUserId String
  nameKey     String   @db.VarChar(200)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User @relation("NamePrefOwner", fields: [ownerUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  preferred User @relation("NamePrefTarget", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([ownerUserId, nameKey])
  @@index([ownerUserId])
}

// ── AI Query History & Cache ────────────────────────────────

model AiQuery {
  id              String    @id @default(uuid())
  userId          String
  rawQuery        String    @db.Text
  normalizedQuery String    @db.VarChar(1000)
  scope           String // 'user' | 'team'
  targetUserId    String?
  targetName      String?
  rangeFrom       DateTime
  rangeTo         DateTime
  report          String    @db.Text
  meta            String?   @db.Text
  cached          Boolean   @default(false)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())

  user User @relation("AiQueryRequester", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, createdAt])
  @@index([scope, targetUserId, rangeFrom, rangeTo])
  @@index([normalizedQuery])
}

// ── Ideation ────────────────────────────────────────────────

model Idea {
  id          String    @id @default(uuid())
  authorId    String
  title       String
  description String
  tags        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author            User       @relation("IdeaAuthor", fields: [authorId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sourceMatches     IdeaMatch[] @relation("IdeaMatchSourceIdea")
  candidateMatches  IdeaMatch[] @relation("IdeaMatchCandidateIdea")

  @@index([authorId])
  @@index([createdAt])
  @@index([authorId, createdAt])
}

model IdeaMatch {
  id             String   @id @default(uuid())
  ideaId         String
  candidateIdeaId String
  matchedUserId  String
  score          Float
  status         String   @default("SUGGESTED")
  notifiedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  idea          Idea @relation("IdeaMatchSourceIdea", fields: [ideaId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  candidateIdea Idea @relation("IdeaMatchCandidateIdea", fields: [candidateIdeaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  matchedUser   User @relation("IdeaMatchTargetUser", fields: [matchedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([ideaId, candidateIdeaId, matchedUserId])
  @@index([ideaId])
  @@index([matchedUserId, createdAt])
  @@index([score])
}

// ── Social Account Linking ──────────────────────────────────

model SocialAccount {
  id                String   @id @default(uuid())
  userId            String
  platform          String
  platformAccountId String
  handle            String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, platform, platformAccountId])
  @@index([userId])
}

// ── Existing: Social Performance (Meltwater) ────────────────

model InstagramPerformance {
  id              String   @id @default(uuid())
  source          String   @default("instagram")
  sourceItemId    String   @unique
  language        String
  mentionCount    Int      @default(0)
  estimatedViews  Int      @default(0)
  estimatedReach  Int      @default(0)
  engagement      Int      @default(0)
  engagementCount Int      @default(0)
  engagementRate  Float    @default(0)
  sentiment       String   @default("unknown")
  mentionedAt     DateTime
  rawPayload      String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([mentionedAt])
  @@index([source, mentionedAt])
  @@index([language, mentionedAt])
  @@index([source, language, mentionedAt])
}

// ── Content Module ──────────────────────────────────────────

model Content {
  id          String   @id @default(uuid())
  title       String
  description String?
  type        String // 'PRODUCTION' | 'COVERAGE'
  status      String   @default("DRAFT") // DRAFT | IN_PROGRESS | COMPLETED | ARCHIVED
  teamId      String
  projectId   String
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User?         @relation("ContentCreatedBy", fields: [createdById], references: [id])
  team      Team          @relation(fields: [teamId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project   Project       @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  nodes     ContentNode[]

  @@index([createdById])
  @@index([type])
  @@index([status])
  @@index([teamId])
  @@index([projectId])
}

model ContentNode {
  id          String    @id @default(uuid())
  contentId   String
  kind        String // 'SCRIPTING' | 'SHOOT' | 'EDITING' | ...
  name        String
  orderIndex  Int       @default(0)
  status      String    @default("PENDING") // PENDING | IN_PROGRESS | BLOCKED | COMPLETED
  notes       String?
  startsAt    DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  content   Content                 @relation(fields: [contentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  team      ContentNodeTeamMember[]
  outputs   ContentNodeOutput[]
  resources ContentNodeResource[]
  inventoryReservations InventoryReservation[]

  @@unique([contentId, orderIndex])
  @@index([contentId, orderIndex])
}

model ContentNodeTeamMember {
  id        String   @id @default(uuid())
  nodeId    String
  userId    String
  role      String // global TeamRole enum
  createdAt DateTime @default(now())

  node ContentNode @relation(fields: [nodeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user User        @relation("ContentNodeTeamUser", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([nodeId, userId, role])
  @@index([nodeId])
  @@index([userId])
}

model ContentNodeOutput {
  id                String    @id @default(uuid())
  nodeId            String
  label             String
  url               String
  notes             String?
  version           Int       @default(1)
  submittedByUserId String?
  approvalState     String    @default("PENDING") // PENDING | IN_REVIEW | CHANGES_REQUESTED | APPROVED | REJECTED
  reviewNote        String?
  reviewedByUserId  String?
  reviewedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  node        ContentNode @relation(fields: [nodeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  submittedBy User?       @relation("ContentOutputSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewedBy  User?       @relation("ContentOutputReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([nodeId])
  @@index([nodeId, approvalState])
}

model ContentNodeResource {
  id                String    @id @default(uuid())
  nodeId            String
  name              String
  sourceType        String    @default("IN_HOUSE") // IN_HOUSE | RENTAL
  inventoryItemId   String?
  cost              Decimal?  @db.Decimal(18, 2)
  quantity          Int       @default(1)
  currency          String?
  notes             String?
  // Rental-only review workflow. IN_HOUSE rows stay APPROVED implicitly.
  approvalState     String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewNote        String?
  requestedByUserId String?
  reviewedByUserId  String?
  reviewedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  node            ContentNode           @relation(fields: [nodeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inventoryItem   InventoryItem?          @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  inventoryReservation InventoryReservation?
  requestedBy     User?                 @relation("ResourceRequestedBy", fields: [requestedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewedBy      User?                 @relation("ResourceReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([nodeId])
  @@index([nodeId, sourceType])
  @@index([nodeId, approvalState])
  @@index([inventoryItemId])
}

// ── Inventory (equipment catalog + shoot reservations) ──

model InventoryItem {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(500)
  description  String?  @db.Text
  category     String?  @db.VarChar(200)
  serialNumber String?  @db.VarChar(200)
  status       String   @default("AVAILABLE") // AVAILABLE | IN_USE | MAINTENANCE | RETIRED
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teams        InventoryItemTeam[]
  reservations InventoryReservation[]
  resources    ContentNodeResource[]

  @@index([status])
  @@index([isActive])
  @@index([category])
  @@index([name])
}

model InventoryItemTeam {
  inventoryItemId String
  teamId          String
  isPrimary       Boolean  @default(false)
  assignedAt      DateTime @default(now())

  item InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  team Team          @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([inventoryItemId, teamId])
  @@index([teamId])
}

model InventoryReservation {
  id                    String    @id @default(uuid())
  inventoryItemId       String
  contentNodeId         String
  contentNodeResourceId String    @unique
  reservedFrom          DateTime
  dueBackAt             DateTime
  returnedAt            DateTime?
  status                String    @default("ACTIVE") // ACTIVE | RETURNED | OVERDUE | CANCELLED
  notes                 String?   @db.Text
  createdById           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  item      InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  node      ContentNode         @relation(fields: [contentNodeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  resource  ContentNodeResource @relation(fields: [contentNodeResourceId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  createdBy User?               @relation("InventoryReservationCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([inventoryItemId, status])
  @@index([contentNodeId])
  @@index([dueBackAt])
  @@index([status, dueBackAt])
}

// ── Thumbnail generator utility ──

model ThumbnailGeneration {
  id                     String   @id @default(uuid())
  userId                 String
  inputTitle             String   @db.VarChar(500)
  inputDescription       String   @db.Text
  inputContext           String?  @db.Text
  referencePaths         String   @db.Text
  outputTitle            String   @db.VarChar(500)
  outputTextDescription  String   @db.Text
  outputContext          String   @db.Text
  assets                 String   @db.Text
  designBrief            String   @db.Text
  styleFromReferences    String   @db.Text
  generatedImagePath     String?  @db.VarChar(1000)
  generatedMimeType        String?  @db.VarChar(100)
  generatedFileSizeBytes   Int?
  createdAt              DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, createdAt])
}

// ── Navigation analytics (client nav search + page visits) ──

model NavSearchLog {
  id           String   @id @default(uuid())
  userId       String
  query        String   @db.VarChar(500)
  selectedPath String?  @db.VarChar(500)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, createdAt])
}

model UserPageVisit {
  id            String   @id @default(uuid())
  userId        String
  path          String   @db.VarChar(500)
  visitCount    Int      @default(1)
  lastVisitedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, path])
  @@index([userId, visitCount])
  @@index([userId, lastVisitedAt])
}

// ── Attendance / ETA Tracker (Slack #cs-day-off) ─────────────

model SlackMember {
  slackUserId String    @id @map("slack_user_id")
  name        String?
  email       String?
  realName    String?   @map("real_name")
  isBot       Boolean   @default(false) @map("is_bot")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  syncedAt    DateTime? @map("synced_at")
  pod         String    @default("default") // 'default' | 'production'

  @@map("slack_members")
}

model EtaEntry {
  id               Int       @id @default(autoincrement())
  slackUserId      String?   @map("slack_user_id")
  userEmail        String?   @map("user_email")
  userName         String?   @map("user_name")
  entryDate        DateTime  @map("entry_date") @db.Date
  etaText          String?   @map("eta_text")
  etaMinutes       Int?      @map("eta_minutes")
  status           String // 'submitted' | 'missing'
  recordType       String?   @map("record_type") // 'office' | 'wfh' | 'leave' | 'comp_off'
  submittedAt      DateTime? @map("submitted_at")
  submittedOnTime  Boolean?  @map("submitted_on_time")
  isLateArrival    Boolean?  @map("is_late_arrival")
  rawMessage       String?   @map("raw_message")
  slackMessageTs   String?   @map("slack_message_ts")
  reminderSentAt   DateTime? @map("reminder_sent_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@unique([slackUserId, entryDate])
  @@index([entryDate, recordType], map: "idx_eta_entries_date_type")
  @@index([entryDate, status])
  @@map("eta_entries")
}

/// Rolling per-person attendance counters for manager/admin action.
/// Recomputed from eta_entries (not incremented) so upserts stay accurate.
model AttendancePersonStats {
  id                   String    @id @default(uuid())
  slackUserId          String    @unique @map("slack_user_id")
  userId               String?   @map("user_id")
  userEmail            String?   @map("user_email")
  userName             String?   @map("user_name")
  wfhCount             Int       @default(0) @map("wfh_count")
  leaveCount           Int       @default(0) @map("leave_count")
  compOffCount         Int       @default(0) @map("comp_off_count")
  officeCount          Int       @default(0) @map("office_count")
  onTimeCount          Int       @default(0) @map("on_time_count")
  lateSubmissionCount  Int       @default(0) @map("late_submission_count")
  lateArrivalCount     Int       @default(0) @map("late_arrival_count")
  missingCount         Int       @default(0) @map("missing_count")
  submittedCount       Int       @default(0) @map("submitted_count")
  /// none | flagged | warned | acknowledged | resolved
  actionStatus         String    @default("none") @map("action_status")
  actionNote           String?   @map("action_note") @db.Text
  actionTakenById      String?   @map("action_taken_by_id")
  actionTakenAt        DateTime? @map("action_taken_at")
  lastEntryDate        DateTime? @map("last_entry_date") @db.Date
  lastComputedAt       DateTime  @default(now()) @map("last_computed_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user          User? @relation("AttendanceStatsUser", fields: [userId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  actionTakenBy User? @relation("AttendanceStatsActionBy", fields: [actionTakenById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([userEmail])
  @@index([userId])
  @@index([actionStatus])
  @@index([wfhCount])
  @@index([lateSubmissionCount])
  @@index([missingCount])
  @@map("attendance_person_stats")
}

// ── Notifications ───────────────────────────────────────────

model Notification {
  id          String    @id @default(uuid())
  userId      String
  kind        String // e.g. CONTENT_NODE_READY
  title       String
  body        String?
  // JSON-encoded structured payload (output, fromNode, toNode, contentId, ...)
  data        String?
  // Idempotency key so the same trigger never produces duplicate rows.
  dedupeKey   String?
  readAt      DateTime?
  emailSentAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, dedupeKey])
  @@index([userId, readAt])
  @@index([userId, createdAt])
}
